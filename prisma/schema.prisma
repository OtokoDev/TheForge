generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String          @id @default(cuid())
  discordId      String          @unique
  username       String
  inGameName     String?
  avatar         String?
  role           Role            @default(FORGERON)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  orders         Order[]
  shopSessions   ShopSession[]
  stockMovements StockMovement[]
  activityLogs   ActivityLog[]
  announcements  Announcement[]
}

enum Role {
  ADMIN
  GERANT
  FORGERON
}

model Product {
  id            String        @id @default(cuid())
  name          String
  description   String?
  category      String        @default("Divers")
  categoryRef   Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId    String?
  imageUrl      String?
  sellPrice     Float
  itemType      ItemType      @default(OTHER)
  handRequired  HandRequired?
  finishedStock Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  recipe        Recipe[]
  orderItems    OrderItem[]
}

enum ItemType {
  DAGGER
  SWORD
  AXE
  MACE
  BOW
  ARMOR
  BOOTS
  GLOVES
  HELMET
  SHIELD
  RESOURCE
  OTHER
}

enum HandRequired {
  ONE
  TWO
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Ingredient {
  id                String                     @id @default(cuid())
  name              String
  unit              String                     @default("unité")
  unitCost          Float                      @default(0)
  materialType      MaterialType               @default(RAW)
  buybackDetail     String?
  currentStock      Int                        @default(0)
  alertThreshold    Int                        @default(5)
  isActive          Boolean                    @default(true)
  createdAt         DateTime                   @default(now())
  recipes           Recipe[]
  stockMovements    StockMovement[]
  orderConsumptions OrderResourceConsumption[]
}

enum MaterialType {
  RAW
  TRANSFORMED
}

model Recipe {
  id           String     @id @default(cuid())
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  ingredientId String
  quantity     Int

  @@unique([productId, ingredientId])
}

model StockMovement {
  id           String       @id @default(cuid())
  ingredient   Ingredient   @relation(fields: [ingredientId], references: [id])
  ingredientId String
  type         MovementType
  quantity     Int
  reason       String?
  user         User         @relation(fields: [userId], references: [id])
  userId       String
  createdAt    DateTime     @default(now())
}

enum MovementType {
  IN
  OUT
}

model Order {
  id           String                     @id @default(cuid())
  orderNumber  Int                        @unique @default(autoincrement())
  user         User                       @relation(fields: [userId], references: [id])
  userId       String
  status       OrderStatus                @default(EN_ATTENTE)
  totalPrice   Float
  totalCost    Float                      @default(0)
  totalProfit  Float                      @default(0)
  smithShare   Float                      @default(0)
  companyShare Float                      @default(0)
  clientNote   String?
  internalNote String?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  deliveredAt  DateTime?
  items        OrderItem[]
  consumptions OrderResourceConsumption[]
}

enum OrderStatus {
  EN_ATTENTE
  EN_FABRICATION
  PRETE
  LIVREE
  ANNULEE
}

model OrderItem {
  id          String          @id @default(cuid())
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  product     Product         @relation(fields: [productId], references: [id])
  productId   String
  quantity    Int
  unitPrice   Float
  unitCost    Float           @default(0)
  itemSource  OrderItemSource @default(MADE_NOW)
  stockBefore Int?
  stockAfter  Int?
}

enum OrderItemSource {
  MADE_NOW
  FROM_STOCK
}

model OrderResourceConsumption {
  id           String     @id @default(cuid())
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId String
  quantity     Int
  unitCost     Float
  totalCost    Float
  createdAt    DateTime   @default(now())
}

model ShopSession {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  ordersCount Int       @default(0)
  totalSales  Float     @default(0)
  totalProfit Float     @default(0)
}

model WebhookLog {
  id        String   @id @default(cuid())
  type      String
  payload   String
  success   Boolean
  error     String?
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model Announcement {
  id        String            @id @default(cuid())
  title     String
  message   String
  color     AnnouncementColor
  isActive  Boolean           @default(true)
  author    User              @relation(fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime          @default(now())
}

enum AnnouncementColor {
  GREEN
  YELLOW
  RED
}
