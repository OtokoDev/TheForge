# Exemple d'environnement de DÉPLOIEMENT (VPS). Copier en `.env` dans /opt/theforge.
# NE PAS committer le .env réel. (Le .env.example racine est pour le DEV local.)

# Image Docker publiée par la CI sur Docker Hub. Le VPS la « pull ».
THEFORGE_IMAGE=bryanguerin/theforge:latest

# ── Base de données (PostgreSQL système de l'hôte, base `theforge`) ───────────
POSTGRES_USER=theforge
POSTGRES_PASSWORD=change-me-strong-db-password

# UID/GID du user hôte propriétaire des logs (id -u / id -g, souvent 1000/1000).
PUID=1000
PGID=1000

# ── Sécurité ─────────────────────────────────────────────────────────────────
# openssl rand -base64 48
JWT_GENERATOR_SIGNATURE_SECRET=change-me-with-a-long-random-secret-min-32-chars

# ── OAuth2 Discord ───────────────────────────────────────────────────────────
# Redirect URI à déclarer côté Discord : https://forge.mondomaine.fr/oauth/callback/discord
DISCORD_CLIENT_ID=000000000000000000
DISCORD_CLIENT_SECRET=change-me
FORGE_OWNER_DISCORD_ID=

# ── Webhooks Discord (optionnels) ────────────────────────────────────────────
DISCORD_WEBHOOK_SHOP=
DISCORD_WEBHOOK_ORDERS=

# Vide = front embarqué même origine (recommandé). Pas de CORS, redirections relatives.
FRONT_ORIGIN=

JAVA_OPTS=-Xmx512m
